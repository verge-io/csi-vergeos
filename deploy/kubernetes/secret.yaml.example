# Copy this file to secret.yaml and fill in your VergeOS API credentials.
# Apply with: kubectl apply -f deploy/kubernetes/secret.yaml
#
# NEVER commit the filled-in secret.yaml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: vergeos-credentials
  namespace: kube-system
type: Opaque
stringData:
  VERGEOS_HOST: "https://your-vergeos-instance.example.com"
  VERGEOS_API_KEY: "your-api-key-here"
  VERGEOS_VERIFY_SSL: "true"
